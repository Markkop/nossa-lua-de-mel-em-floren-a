# PIX Copia e Cola codes - one for each gift amount
# Replace the placeholder values with your actual PIX codes generated from your bank app
# Each code corresponds to a specific gift amount in BRL

VITE_PIX_CODE_50=PIX_PLACEHOLDER_50
VITE_PIX_CODE_100=PIX_PLACEHOLDER_100
VITE_PIX_CODE_250=PIX_PLACEHOLDER_250
VITE_PIX_CODE_500=PIX_PLACEHOLDER_500
VITE_PIX_CODE_1000=PIX_PLACEHOLDER_1000
VITE_PIX_CODE_2000=PIX_PLACEHOLDER_2000

# Google Maps API Key (required for Google Maps view and geocoding on /hospedagem page)
# Get your API key at: https://console.cloud.google.com/google/maps-apis
# IMPORTANT: Enable BOTH of these APIs:
#   1. Maps JavaScript API (for displaying the map)
#   2. Geocoding API (for converting addresses to coordinates)
# If not provided, the map will show an error message. 
# To use OpenStreetMap instead (free), change MAP_PROVIDER to 'leaflet' in components/map/map-shared.ts
# Note: Geocoded coordinates are cached in browser localStorage to minimize API calls.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Karaoke API (server-only — used by server/main.ts, not prefixed with VITE_)
# Copy DATABASE_URL from Neon (project "karaoke" or your dedicated project).
DATABASE_URL=
KARAOKE_DJ_PIN=0000
KARAOKE_JWT_SECRET=change-me-in-production
KARAOKE_SERVER_PORT=8787

# Client: how often to poll GET /api/karaoke/state (milliseconds). Default 60000 (~1 min). Minimum 1000.
# VITE_KARAOKE_POLL_MS=60000

# Optional: if the SPA and API are on different origins (production)
# VITE_KARAOKE_API_URL=https://api.example.com

# --- Vercel / production ---
# Set DATABASE_URL, KARAOKE_DJ_PIN, and KARAOKE_JWT_SECRET in the host dashboard (Vercel: Project → Settings → Environment Variables).
# Do not prefix those with VITE_; they are server-only. If the SPA and API share the same origin (e.g. karaoke.example.com), leave VITE_KARAOKE_API_URL unset so the client calls /api/karaoke/* on the same host.
